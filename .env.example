# =============================================================
# CX_lab Dojo env template
# Copy to .env and fill in real values. Never commit real secrets.
# =============================================================

# Google / Gemini
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional: default voice id. Blank means provider default.
ELEVENLABS_VOICE_ID=

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# DigitalOcean / Database
DIGITAL_OCEAN_API_KEY=your-digitalocean-token
DATABASE_URL=postgresql://<username>:<password>@<host_url>:<port>/<database_name>?sslmode=require

# App config
PORT=8000
# Default TTS provider: google | elevenlabs
TTS_PROVIDER=google
